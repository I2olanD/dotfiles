{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["cc-safety-net"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "clockodo": {
      "type": "local",
      "command": ["npx", "-y", "clockodo-mcp@latest"]
    }
  }
}
